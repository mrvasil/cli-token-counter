# CLIProxyAPI Management API base URL.
# Local Node run:
# MANAGEMENT_URL=http://127.0.0.1:8317/v0/management
# Docker on macOS/Windows, when CLIProxyAPI runs on the host:
MANAGEMENT_URL=http://host.docker.internal:8317/v0/management

# CLIProxyAPI remote-management.secret-key.
MANAGEMENT_KEY=change-me

# Web server.
PORT=4173

# Polling and rate windows.
POLL_INTERVAL_MS=5000
AUTH_POLL_INTERVAL_MS=10000
RATE_WINDOW_SEC=300
CHART_WINDOW_SEC=14400
CHART_BUCKETS=48
CODEX_RATE_HISTORY_MS=900000
CODEX_QUOTA_CONCURRENCY=6

# Optional endpoint overrides. Usually leave empty and use MANAGEMENT_URL.
# MANAGEMENT_USAGE_URL=https://example.com/v0/management/usage
# MANAGEMENT_AUTH_FILES_URL=https://example.com/v0/management/auth-files
# MANAGEMENT_API_CALL_URL=https://example.com/v0/management/api-call

# Codex quota endpoint used via CLIProxyAPI /api-call.
CODEX_USAGE_URL=https://chatgpt.com/backend-api/wham/usage

# Optional price overrides, USD per 1M tokens.
# MODEL_PRICES_JSON={"gpt-5.5":{"prompt":5,"cache":0.5,"completion":30},"gpt-5.4":{"prompt":2.5,"cache":0.25,"completion":15},"gpt-5.4-mini":{"prompt":0.75,"cache":0.075,"completion":4.5},"gpt-5.3-codex":{"prompt":1.75,"cache":0.175,"completion":14}}
